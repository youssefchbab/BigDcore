Library ieee;
use ieee.std_logic_1164.all;

entity Register is
    generic(N: integer := 32);
    port (
        clk,Reset: in std_logic;
        D: in std_logic_vector(N-1 downto 0) ;
        Q: out std_logic_vector(N-1 downto 0) ;

    ) ;
end Register;

architecture arch of Register is

begin
    Process (clk) Begin 
        if( Rising_edge(clk) )then
            if( Reset='1' ) then
                Q<=(others=>'0');
            else
                Q<=D;
            end if;
        end if;
    end process;
end arch ; -- arch